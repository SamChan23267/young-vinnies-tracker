# Young Vinnies Tracker - Environment Variables
# Copy this file to .env and update with your actual values

# Server Configuration
NODE_ENV=production
PORT=3000

# Session Secret (REQUIRED - Generate a strong random string)
# You can generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=your-super-secret-random-string-here-change-this

# Session Cookie Settings
COOKIE_SECURE=true
COOKIE_MAX_AGE=86400000

# Rate Limiting (requests per 15 minutes)
RATE_LIMIT_MAX=250

# Logging
LOG_LEVEL=combined

# ------------------------------------------------------------------
# Vercel KV (Upstash Redis) - REQUIRED for Vercel deployments
# ------------------------------------------------------------------
# Vercel runs multiple simultaneous function instances, each with its
# own private memory and /tmp filesystem.  Without KV every instance
# has a different view of the data ("parallel universes").  KV is a
# shared store that is visible to all instances at once.
#
# Setup steps:
#   1. Open your project in the Vercel dashboard.
#   2. Go to Storage → Create Database → KV (Upstash).
#   3. Follow the wizard; Vercel will add the env vars below
#      automatically to your project.
#   4. Redeploy so the new env vars take effect.
#
# The two variables below are set automatically by Vercel when you
# connect a KV database.  You do NOT need to set them manually on
# Vercel - they appear here only so local development can optionally
# point at the same KV store.
#
# KV_REST_API_URL=https://your-kv-url.upstash.io
# KV_REST_API_TOKEN=your-kv-token
